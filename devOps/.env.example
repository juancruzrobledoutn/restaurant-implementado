# devOps -- Docker Compose environment variables
# Copy to .env before running docker compose.
# Never commit .env to git.

# -- PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=menu_ops

# -- pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# -- Redis (port 6380 external, 6379 internal)
REDIS_PORT=6380

# -- Auth secrets (used by backend service in docker-compose)
# REQUIRED: change these in any non-local environment
JWT_SECRET=
JWT_ISSUER=menu-ops
JWT_AUDIENCE=menu-ops-users
TABLE_TOKEN_SECRET=

# -- JWT expiry
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_TABLE_TOKEN_EXPIRE_HOURS=3

# -- TLS / Domain (C-23: monitoring-production)
# Your production domain (no https:// prefix, no trailing slash)
# Example: app.myrestaurant.com
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=admin@yourdomain.com

# -- Monitoring -- Grafana
# Admin password for Grafana web UI
# Generate with: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# -- Monitoring -- Alertmanager
# Webhook URL for alert notifications (Slack, PagerDuty, etc.)
# Leave empty to disable outbound alerts (alerts still visible in Alertmanager UI)
ALERTMANAGER_WEBHOOK_URL=

# -- Loki log retention (Prometheus duration format)
LOKI_RETENTION_PERIOD=720h
