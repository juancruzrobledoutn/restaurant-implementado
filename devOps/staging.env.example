# =============================================================================
# Staging Environment Variables — Integrador
# =============================================================================
#
# Copy this file to devOps/.env (or paste into EasyPanel env vars panel) and
# fill ALL values before deploying.
#
# Generate secrets with:
#   openssl rand -base64 32
# =============================================================================

# ----- PostgreSQL -----
POSTGRES_DB=integrador_staging
POSTGRES_USER=integrador
# CHANGE THIS — strong password, no defaults in staging
POSTGRES_PASSWORD=

# ----- JWT (backend + ws_gateway) -----
# Min 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_ISSUER=integrador-staging
JWT_AUDIENCE=integrador-users
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_TABLE_TOKEN_EXPIRE_HOURS=3

# ----- Table Token (HMAC for diner sessions in pwaMenu) -----
# Min 32 characters. Different from JWT_SECRET. Generate with: openssl rand -base64 32
TABLE_TOKEN_SECRET=
TABLE_TOKEN_TTL_SECONDS=10800

# ----- CORS — Backend (REST API) -----
# Comma-separated. Include the Vercel URLs of all 3 frontends.
# Example:
#   ALLOWED_ORIGINS=https://dashboard-staging.vercel.app,https://menu-staging.vercel.app,https://waiter-staging.vercel.app
ALLOWED_ORIGINS=

# ----- CORS — WebSocket Gateway -----
# Comma-separated. Same Vercel URLs as ALLOWED_ORIGINS.
WS_ALLOWED_ORIGINS=

# ----- WebSocket Gateway tuning -----
WS_MAX_CONNECTIONS=200
WS_MAX_CONNECTIONS_PER_USER=3
WS_BROADCAST_WORKERS=5
WS_BROADCAST_QUEUE_SIZE=2000
WS_STREAM_CRITICAL=events:critical
WS_STREAM_GROUP=ws_gateway_group
WS_STREAM_DLQ=events:dlq
