{
  "title": "Infrastructure",
  "uid": "integrador-infrastructure",
  "description": "Redis memory and clients, PostgreSQL connections, WebSocket connection counts",
  "tags": ["integrador", "infrastructure", "redis", "postgres", "websocket"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "editable": false,
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Redis Memory Used",
      "description": "Redis resident memory in bytes. Alert if approaching the 512MB container limit.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "integrador-prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "maxmemory limit",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "maxmemory limit" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 2,
      "title": "Redis Connected Clients",
      "description": "Number of client connections to Redis (backend + ws_gateway + exporters)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "integrador-prometheus" },
      "targets": [
        {
          "expr": "redis_connected_clients{job=\"redis\"}",
          "legendFormat": "connected clients",
          "refId": "A"
        },
        {
          "expr": "redis_blocked_clients{job=\"redis\"}",
          "legendFormat": "blocked clients",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "blocked clients" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] }
      }
    },
    {
      "id": 3,
      "title": "PostgreSQL Active Connections",
      "description": "Number of active database connections (max_connections=200 in prod config)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "integrador-prometheus" },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{job=\"postgres\", state=\"active\"})",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "sum(pg_stat_activity_count{job=\"postgres\", state=\"idle\"})",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "sum(pg_stat_activity_count{job=\"postgres\", state=\"idle in transaction\"})",
          "legendFormat": "idle in transaction",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "idle in transaction" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] }
      }
    },
    {
      "id": 4,
      "title": "WebSocket Active Connections",
      "description": "Currently active WebSocket connections across all ws_gateway instances",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "integrador-prometheus" },
      "targets": [
        {
          "expr": "sum(websocket_connections_active{job=\"ws_gateway\"})",
          "legendFormat": "active WS connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 500, "color": "orange" },
              { "value": 900, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Redis Keyspace Hits vs Misses",
      "description": "Cache hit ratio. Low hit rate may indicate cache invalidation issues.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "integrador-prometheus" },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[5m])",
          "legendFormat": "hits/s",
          "refId": "A"
        },
        {
          "expr": "rate(redis_keyspace_misses_total{job=\"redis\"}[5m])",
          "legendFormat": "misses/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "misses/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }
      }
    },
    {
      "id": 6,
      "title": "PostgreSQL Transaction Rate",
      "description": "Committed and rolled-back transactions per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "integrador-prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres\"}[5m])",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres\"}[5m])",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rollbacks/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }
      }
    }
  ]
}
