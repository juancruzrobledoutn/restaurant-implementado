# Load Test Environment Configuration
# Copy to .env and adjust for your target environment

# REST API base URL (no trailing slash)
BASE_URL=http://localhost:8000

# WebSocket Gateway URL (no trailing slash)
WS_URL=ws://localhost:8001

# Test users (must exist in the target database)
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=admin123
WAITER_EMAIL=waiter@demo.com
WAITER_PASSWORD=waiter123
KITCHEN_EMAIL=kitchen@demo.com
KITCHEN_PASSWORD=kitchen123

# Branch slug for public menu tests
BRANCH_SLUG=centro
