# e2e test environment - copy to .env.test and fill in values
# .env.test is gitignored; this file is committed as the reference template

# App base URLs (must match running dev/preview servers or docker-compose ports)
BASE_URL_DASHBOARD=http://localhost:5177
BASE_URL_MENU=http://localhost:5176
BASE_URL_WAITER=http://localhost:5178

# Backend API base URL
API_URL=http://localhost:8000

# HMAC secret for generating X-Table-Token in fixtures
# Must match TABLE_TOKEN_SECRET in backend .env / docker-compose
TABLE_TOKEN_SECRET=test-table-secret-at-least-32-chars

# Admin credentials used by ApiHelper to seed test data
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=changeme

# Waiter credentials for waiter-flow spec
TEST_WAITER_EMAIL=waiter@example.com
TEST_WAITER_PASSWORD=changeme

# Kitchen credentials for kitchen-flow spec
TEST_KITCHEN_EMAIL=kitchen@example.com
TEST_KITCHEN_PASSWORD=changeme
